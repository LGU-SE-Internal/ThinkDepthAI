# ThinkDepthAI Environment Variables
# Copy this file to .env and fill in the values

# LLM Provider Configuration
UTU_LLM_TYPE=chat.completions
UTU_LLM_MODEL=gpt-4o
UTU_LLM_BASE_URL=https://api.openai.com/v1
UTU_LLM_API_KEY=sk-xxx

# Database (for evaluation)
# LLM_EVAL_DB_URL=sqlite:///eval.db

# Logging
# UTU_LOG_LEVEL=WARNING
