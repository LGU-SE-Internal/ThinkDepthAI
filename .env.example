# ThinkDepthAI Environment Variables
# Copy this file to .env and fill in the values

# LLM Provider Configuration
UTU_LLM_TYPE=chat.completions
UTU_LLM_MODEL=Doubao-Seed-2.0-pro
UTU_LLM_BASE_URL=http://100.108.164.93:4000/v1
UTU_LLM_API_KEY=


LLM_EVAL_DB_URL=""
NOTIFY_FEISHU_WEBHOOK_URL=""

# Path to the OpenRCA-2.0-Lite v1 snapshot (must contain MANIFEST.json).
# Only needed for the lite_v1 evaluation flow (scripts/seed_lite_v1_db.py +
# config/eval/openrca2_lite_v1.yaml). Pull the snapshot once with:
#   hf download lincyaw/openrca2-lite-v1 --repo-type dataset --local-dir ./data/openrca2_lite_v1
# Then point this at that directory.
LITE_V1_ROOT=./data/openrca2_lite_v1
